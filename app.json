{
  "expo": {
    "name": "BHIMR Universal Calculator",
    "slug": "bhim-calculator",
    "version": "9.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bhimcalculator",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bhimcalculator.app"
    },
    "android": {
  "package": "com.bhimcalculator.app",
  "versionCode": 9,

  "permissions": [
    "INTERNET",
    "ACCESS_NETWORK_STATE",
    "RECORD_AUDIO",
    "MODIFY_AUDIO_SETTINGS"
  ],

  "config": {
    "googleMobileAdsAppId": "ca-app-pub-4355119717560830~9966082989"
  },

  "adaptiveIcon": {
    "foregroundImage": "./assets/images/adaptive-icon.png",
    "backgroundColor": "#ffffff"
  }
},

   

    
  
  
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-speech-recognition",
      "expo-web-browser",
      [
  "react-native-google-mobile-ads",
  {
    "androidAppId": "ca-app-pub-4355119717560830~9966082989",
    "iosAppId": "ca-app-pub-4355119717560830~9966082989",
    "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you.",
    "delayAppMeasurementInit": true
  }
]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b6e47504-0a87-4567-874b-7500477182cd"
      }
    },
    "owner": "vishalmsk5"
  }
}
